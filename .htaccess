PassengerEnabled on
PassengerAppRoot /home/SEU_USUARIO/novel
PassengerBaseURI /

# ─── Bloqueia acesso direto a arquivos sensíveis ───────────────────────────
<FilesMatch "(\.env|\.db|\.pyc|requirements\.txt|passenger_wsgi\.py)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloqueia listagem de diretórios
Options -Indexes

# Bloqueia acesso ao __pycache__
<DirectoryMatch "__pycache__">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# ─── Redireciona tudo para o Passenger (Flask) ─────────────────────────────
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
